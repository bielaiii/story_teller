{
  "name": "story-teller",
  "private": true,
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "tsc -b && vite build --config vite.config.ts",
    "test:unit": "./scripts/python.sh -m unittest discover -s tests/v3 -v",
    "test:frontend": "vitest run",
    "test:e2e:v3": "playwright test --config playwright.v3.config.js",
    "test:e2e:static": "playwright test --config playwright.static.config.js"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/markdown-it": "14.1.2",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/commands": "6.10.4",
    "@codemirror/lang-markdown": "6.5.1",
    "@codemirror/search": "6.7.1",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@tanstack/react-query": "5.101.2",
    "codemirror": "6.0.2",
    "dompurify": "3.4.12",
    "markdown-it": "14.3.0",
    "pinyin-pro": "3.28.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "5.0.14"
  }
